<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Inherit Spring Boot defaults -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Surge calibration file appender — structured logs for post-MVP comparison
         against NTSLF observed surge residuals. Only significant surges are logged. -->
    <appender name="SURGE_CALIBRATION" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/surge-calibration.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/surge-calibration.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="surge.calibration" level="INFO" additivity="false">
        <appender-ref ref="SURGE_CALIBRATION"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
